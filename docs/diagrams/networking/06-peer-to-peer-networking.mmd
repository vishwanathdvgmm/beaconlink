    %% Peer Communication
    %% =====================================================

    subgraph Peer["Peer-to-Peer Data Plane"]

        Sync["Artifact Synchronization"]

        Transfer["Large File Transfer"]

        Replication["State Replication"]

        Streaming["Data Streaming"]

    end

    Establish --> Sync
    Establish --> Transfer
    Establish --> Replication
    Establish --> Streaming

    Sync <---> AgentA
    Sync <---> AgentB

    Transfer <---> AgentA
    Transfer <---> AgentB

    Replication <---> AgentB
    Replication <---> AgentC

    Streaming <---> AgentA
    Streaming <---> AgentC

    %% =====================================================
    %% Control Channel
    %% =====================================================

    subgraph ControlChannel["Control Channel"]

        Commands["Control Messages"]

        Status["Session Status"]

        Audit["Audit Events"]

    end

    Router --> Commands

    Commands --> AgentA
    Commands --> AgentB
    Commands --> AgentC

    AgentA --> Status
    AgentB --> Status
    AgentC --> Status

    Status --> Router
    Audit --> Router

    %% =====================================================
    %% Security
    %% =====================================================

    subgraph Security["Peer Security"]

        Identity["Identity Verification"]

        MTLS["Mutual TLS"]

        Tokens["Short-Lived Session Tokens"]

        Encryption["End-to-End Encryption"]

    end

    Authorize --> Identity
    Identity --> MTLS
    MTLS --> Tokens
    Tokens --> Encryption
    Encryption --> Establish

    %% =====================================================
    %% Failure Handling
    %% =====================================================

    subgraph Recovery["Connection Recovery"]

        Detect["Session Failure"]

        Retry["Reconnect"]

        Resume["Resume Transfer"]

    end

    Establish -. Failure .-> Detect
    Detect --> Retry
    Retry --> Establish
    Resume --> Transfer

