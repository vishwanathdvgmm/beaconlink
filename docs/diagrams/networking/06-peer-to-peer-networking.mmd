        Policy["Policy Engine"]

    end

    %% =====================================================
    %% Relay Network
    %% =====================================================

    subgraph Relay["Relay Network"]

        Router["Relay Router"]

        RelayA["Relay A"]
        RelayB["Relay B"]
        RelayC["Relay C"]

        Router --> RelayA
        Router --> RelayB
        Router --> RelayC

        RelayA <-. Federation .-> RelayB
        RelayB <-. Federation .-> RelayC
        RelayC <-. Federation .-> RelayA

    end

    Planner --> Router
    Scheduler --> Router
    Workflow --> Router
    Policy --> Router

    %% =====================================================
    %% Sites
    %% =====================================================

    subgraph SiteA["Production Site A"]

        AgentA["BeaconLink Agent"]

        RuntimeA["Runtime Adapter"]

    end

    subgraph SiteB["Production Site B"]

        AgentB["BeaconLink Agent"]

        RuntimeB["Runtime Adapter"]

    end

    subgraph SiteC["Edge Site"]

        AgentC["BeaconLink Agent"]

        RuntimeC["Runtime Adapter"]

    end

    RelayA --> AgentA
    RelayB --> AgentB
    RelayC --> AgentC

    AgentA --> RuntimeA
    AgentB --> RuntimeB
    AgentC --> RuntimeC

    %% =====================================================
    %% Peer Session Negotiation
    %% =====================================================

    subgraph Negotiation["Peer Session Establishment"]

        Request["Peer Session Request"]

        Authorize["Policy Authorization"]

        Discover["Peer Discovery"]

