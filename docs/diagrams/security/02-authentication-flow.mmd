    classDef gateway fill:#E8F5E9,stroke:#2E7D32,color:#000
    classDef identity fill:#FFF3E0,stroke:#EF6C00,color:#000
    classDef authorization fill:#F3E5F5,stroke:#8E24AA,color:#000
    classDef security fill:#FCE4EC,stroke:#C2185B,color:#000
    classDef note fill:#FFFDE7,stroke:#F9A825,color:#000,stroke-dasharray:5 5

    class User,CLI,Service,Agent,API client

    class APIGateway,RateLimit,RequestValidation gateway

    class IdP,MFA,MTLS,OIDC,Certificate,Verify,Expiration,Revocation,Trust identity

    class IdentityContext,RBAC,ABAC,Policy,Decision,Token,SessionID authorization

    class Control,Workflow,Scheduler,Secrets,Relay,Inventory,Audit,Event,Reject,Log,Alert,Lock,Heartbeat,TokenCheck,PolicyCheck,Renewal security

    class Methods,Principles note