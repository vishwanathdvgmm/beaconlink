    %% Security Analytics
    %% =====================================================

    subgraph Analytics["Security Analytics"]

        Detection["Threat Detection"]

        Compliance["Compliance Reporting"]

        Behavior["Behavior Analytics"]

        Risk["Risk Scoring"]

    end

    Immutable --> Detection
    Immutable --> Compliance
    Immutable --> Behavior

    Detection --> Risk

    %% =====================================================
    %% Operations
    %% =====================================================

    subgraph Operations["Security Operations"]

        Dashboard["Security Dashboard"]

        SIEM["SIEM Integration"]

        Alerts["Alert Manager"]

        Incident["Incident Response"]

    end

    Detection --> Dashboard
    Detection --> Alerts

    Compliance --> Dashboard
    Behavior --> Dashboard

    Immutable --> SIEM

    Alerts --> Incident
    Risk --> Incident

