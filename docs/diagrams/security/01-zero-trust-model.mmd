        Encryption["End-to-End Encryption"]

    end

    Decision --> Gateway
    Gateway --> Relay
    Relay --> Session
    Session --> Encryption

    %% =====================================================
    %% Protected Resources
    %% =====================================================

    subgraph Resources["Protected Resources"]

        Control["Control Plane"]

        Workflow["Workflow Engine"]

        Scheduler["Distributed Scheduler"]

        Secrets["Secret Management"]

        Runtime["Runtime Adapters"]

        Data["Platform Data"]

    end

    Encryption --> Control
    Encryption --> Workflow
    Encryption --> Scheduler
    Encryption --> Secrets
    Encryption --> Runtime
    Encryption --> Data

    %% =====================================================
    %% Continuous Verification
    %% =====================================================

    subgraph Verification["Continuous Verification"]

        Heartbeat["Agent Heartbeats"]

        SessionCheck["Session Validation"]

        PolicyEval["Policy Re-Evaluation"]

        Risk["Risk Assessment"]

    end

    Control --> Heartbeat

    Heartbeat --> SessionCheck
    SessionCheck --> PolicyEval
    PolicyEval --> Risk

    Risk --> Decision

    %% =====================================================
    %% Threat Detection
    %% =====================================================

    subgraph Detection["Threat Detection"]

        Audit["Audit Logs"]

        Events["Security Events"]

        Anomaly["Anomaly Detection"]

        Response["Automated Response"]

    end

    Decision --> Audit

    Heartbeat --> Events
    SessionCheck --> Events
    PolicyEval --> Events

    Audit --> Anomaly
    Events --> Anomaly
    Anomaly --> Response

    %% =====================================================
    %% Incident Response
    %% =====================================================

    subgraph Incident["Incident Response"]

        Revoke["Revoke Credentials"]

        Isolate["Isolate Session"]

        Rotate["Rotate Certificates"]

        Notify["Notify Operators"]

    end

    Response --> Revoke
    Revoke --> Isolate
    Isolate --> Rotate
    Rotate --> Notify

