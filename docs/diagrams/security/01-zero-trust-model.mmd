    %% =====================================================

    subgraph Authentication["Identity & Authentication"]

        Auth["Identity Provider"]

        MFA["Multi-Factor Authentication"]

        MTLS["Mutual TLS"]

        Tokens["Short-Lived Tokens"]

        Certs["Certificate Validation"]

    end

    Auth --> MFA
    Auth --> MTLS
    Auth --> Tokens
    MTLS --> Certs

    %% =====================================================
    %% Authorization
    %% =====================================================

    subgraph Authorization["Policy-Based Authorization"]

        RBAC["RBAC"]

        ABAC["Attribute-Based Access"]

        Policy["Policy Engine"]

        Decision["Authorization Decision"]

    end

    MFA --> RBAC
    Tokens --> ABAC
    Certs --> ABAC

    RBAC --> Policy
    ABAC --> Policy
    Policy --> Decision

    %% =====================================================
    %% Secure Communication
    %% =====================================================

    subgraph Network["Secure Communication"]

