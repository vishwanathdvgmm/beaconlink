    %% =====================================================

    subgraph Principles["Zero Trust Principles"]

        Verify["Verify Explicitly"]
        Least["Least Privilege"]
        Assume["Assume Breach"]
        Continuous["Continuous Validation"]

    end

    %% =====================================================
