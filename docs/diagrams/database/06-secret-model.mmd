---
title: BeaconLink Secret Data Model
---

classDiagram
    direction TB

    %% =====================================================
    %% Secret Definition
    %% =====================================================

    class Secret {
        +UUID id
        +String name
        +SecretType type
        +SecretStatus status
        +RotationPolicy rotationPolicy
        +DateTime createdAt
        +DateTime updatedAt
    }

    class SecretVersion {
        +UUID id
        +Integer version
        +Checksum checksum
        +Boolean current
        +DateTime createdAt
    }

    class SecretReference {
        +UUID id
        +String alias
        +ReferenceType type
    }

    %% =====================================================
    %% Providers
    %% =====================================================

    class SecretProvider {
        +UUID id
        +ProviderType type
        +String name
        +ProviderStatus status
    }

    class Vault {
        +String endpoint
        +AuthenticationMethod auth
    }

    class CloudSecrets {
        +CloudProvider provider
        +Region region
    }

    %% =====================================================
    %% Access Control
    %% =====================================================

    class Policy {
        +UUID id
        +String name
    }

    class ServiceIdentity {
        +UUID id
        +String identity
        +IdentityType type
    }

    class AccessGrant {
        +UUID id
        +AccessMode permission
        +DateTime expiresAt
    }

    %% =====================================================
    %% Consumption
    %% =====================================================

    class Deployment {
        +UUID id
        +String name
    }

    class Resource {
        +UUID id
        +String kind
        +String name
    }

    class Agent {
        +UUID id
        +String hostname
    }

    %% =====================================================
    %% Audit
    %% =====================================================

    class SecretAccess {
        +UUID id
        +AccessResult result
        +DateTime timestamp
    }

    class AuditRecord {
        +UUID id
        +String action
        +DateTime timestamp
    }

    class Event {
        +UUID id
        +String type
        +EventSeverity severity
    }

    %% =====================================================
    %% Relationships
    %% =====================================================

    Secret "1" --> "*" SecretVersion : versioned as

    Secret --> "*" SecretReference : exposed as

    Secret --> "1" SecretProvider : stored by

    SecretProvider <|-- Vault
    SecretProvider <|-- CloudSecrets

    Policy --> "*" AccessGrant : defines

    ServiceIdentity --> "*" AccessGrant : receives

    AccessGrant --> "*" Secret : authorizes

    Deployment --> "*" SecretReference : references

    Resource --> "*" SecretReference : consumes

    Agent --> "*" SecretAccess : requests

    SecretAccess --> Secret : retrieves

    SecretAccess --> AuditRecord : recorded as

    SecretAccess --> Event : publishes

    Secret --> "*" AuditRecord : audited

    %% =====================================================
    %% Styling
    %% =====================================================

    classDef secret fill:#E3F2FD,stroke:#1565C0,color:#000
    classDef provider fill:#E8F5E9,stroke:#2E7D32,color:#000
    classDef access fill:#FFF3E0,stroke:#EF6C00,color:#000
    classDef consumer fill:#F3E5F5,stroke:#8E24AA,color:#000
    classDef audit fill:#FCE4EC,stroke:#C2185B,color:#000

    class Secret,SecretVersion,SecretReference secret

    class SecretProvider,Vault,CloudSecrets provider

    class Policy,ServiceIdentity,AccessGrant access

    class Deployment,Resource,Agent consumer

    class SecretAccess,AuditRecord,Event audit