    %% Error Handling
    %% =====================================================

    subgraph Errors["Failure Handling"]

        Error["Execution Error"]
        Rollback["Compensation / Rollback"]
        Escalate["Manual Approval"]
        Abort["Abort Workflow"]

    end

    Retry --> Error
    Error --> Rollback
    Rollback --> Escalate
    Escalate --> Abort

    %% =====================================================
    %% Events & Observability
    %% =====================================================

    subgraph Events["Observability"]

        Audit["Audit Trail"]
