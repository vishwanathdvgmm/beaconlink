    classDef deployment fill:#E3F2FD,stroke:#1565C0,color:#000
    classDef validation fill:#E8F5E9,stroke:#2E7D32,color:#000
    classDef rollback fill:#FFF3E0,stroke:#EF6C00,color:#000
    classDef execution fill:#F3E5F5,stroke:#8E24AA,color:#000
    classDef completion fill:#FCE4EC,stroke:#C2185B,color:#000
    classDef note fill:#FFFDE7,stroke:#F9A825,color:#000,stroke-dasharray:5 5

    class Deployment,Execution deployment

    class Health,Readiness,Metrics,Policies,Drift,Decision validation

    class Detect,Freeze,Select,Generate,Dispatch rollback

    class Relay,Agent,Runtime,Restore,Verify,Confirm,Reconcile execution

    class Promote,Inventory,AuditSuccess,EventsSuccess,RollbackComplete,Manual,RollbackDecision,Audit,Events completion

    class Triggers,Principles note