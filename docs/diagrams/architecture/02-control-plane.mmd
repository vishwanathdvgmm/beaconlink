flowchart TB

    %% =====================================================
    %% Entry Layer
    %% =====================================================

    Console["BeaconLink Console"]
    REST["REST API"]
    WS["WebSocket API"]

    Console --> Gateway
    REST --> Gateway
    WS --> Gateway

    %% =====================================================
    %% API Layer
    %% =====================================================

    subgraph API["API Layer"]

        Gateway["API Gateway"]

    end

    %% =====================================================
