    %% =====================================================

    subgraph Services["Core Control Plane Services"]

        Deploy["Deployment Engine"]
        Workflow["Workflow Engine"]
        Policy["Policy Engine"]
        Scheduler["Distributed Scheduler"]
        Plugin["Plugin Manager"]
        Secret["Secret Management"]

    end

    %% =====================================================
    %% Platform Services
    %% =====================================================

    subgraph Platform["Platform Services"]

        EventBus["Event Streaming Platform"]

        Metadata["Metadata Store"]
        Audit["Audit Log"]
        Config["Configuration Store"]

    end

    %% =====================================================
    %% External Infrastructure
    %% =====================================================

    subgraph Relay["Relay Layer"]

        RelayCluster["Relay Cluster"]

    end

    %% =====================================================
    %% Gateway Routing
    %% =====================================================

    Gateway --> Deploy
    Gateway --> Workflow
    Gateway --> Policy
    Gateway --> Scheduler
    Gateway --> Plugin
    Gateway --> Secret

    %% =====================================================
    %% Service Dependencies
    %% =====================================================

    Deploy --> Policy
    Deploy --> Workflow
    Deploy --> Secret
    Deploy --> Plugin

    Workflow --> Policy
    Workflow --> Scheduler

    Scheduler --> Workflow

    %% =====================================================
    %% Event-Driven Communication
    %% =====================================================

    Deploy --> EventBus
    Workflow --> EventBus
    Policy --> EventBus
    Scheduler --> EventBus
    Plugin --> EventBus
    Secret --> EventBus

    %% =====================================================
    %% Persistence
    %% =====================================================

    Deploy --> Metadata
    Workflow --> Metadata
    Policy --> Metadata
    Scheduler --> Metadata
    Plugin --> Metadata
    Secret --> Metadata

    EventBus --> Audit

    Config --> Deploy
    Config --> Workflow
    Config --> Policy
    Config --> Scheduler

    %% =====================================================
    %% Relay Integration
    %% =====================================================

    EventBus --> RelayCluster

