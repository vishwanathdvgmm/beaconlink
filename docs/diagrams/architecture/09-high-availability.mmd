    %% Relay Cluster
    %% =====================================================

    subgraph Relay["Relay Cluster"]

        RelayA["Relay A"]
        RelayB["Relay B"]
        RelayC["Relay C"]

    end

    EventBus --> RelayA
    EventBus --> RelayB
    EventBus --> RelayC

    %% =====================================================
    %% Managed Infrastructure
    %% =====================================================

    subgraph Sites["Managed Infrastructure"]

        Agent1["Agent A"]
        Agent2["Agent B"]
        Agent3["Agent C"]
        Agent4["Agent D"]

    end

    Agent1 <-->|Persistent TLS| RelayA
    Agent2 <-->|Persistent TLS| RelayA

    Agent3 <-->|Persistent TLS| RelayB

    Agent4 <-->|Persistent TLS| RelayC

    %% =====================================================
    %% Failover Paths
    %% =====================================================

    RelayA -. Automatic Failover .-> RelayB
    RelayB -. Automatic Failover .-> RelayC
    RelayC -. Automatic Failover .-> RelayA

    Gateway1 -. Health Check .-> Gateway2
    Gateway2 -. Health Check .-> Gateway3
    Gateway3 -. Health Check .-> Gateway1

