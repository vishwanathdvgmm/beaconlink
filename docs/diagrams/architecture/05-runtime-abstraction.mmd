    classDef provider fill:#F3E5F5,stroke:#8E24AA,color:#000;
    classDef runtime fill:#ECEFF1,stroke:#455A64,color:#000;
    classDef feedback fill:#E0F7FA,stroke:#00838F,color:#000;
    classDef note fill:#FFFDE7,stroke:#FBC02D,color:#000,stroke-dasharray: 5 5;

    class Manifest manifest

    class Deploy,Policy,Workflow control

    class RuntimeMgr,Selector,Adapter agent

