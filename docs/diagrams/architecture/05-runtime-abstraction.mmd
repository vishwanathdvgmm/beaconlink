---
title: BeaconLink Runtime Abstraction Layer
---

flowchart TB

    %% =====================================================
    %% Desired State
    %% =====================================================

    Manifest["Site Manifest<br/>Desired State"]

    %% =====================================================
    %% Control Plane
    %% =====================================================

    subgraph ControlPlane["BeaconLink Control Plane"]

        Deploy["Deployment Engine"]
        Policy["Policy Engine"]
        Workflow["Workflow Engine"]

    end

    Manifest --> Deploy
    Deploy --> Policy
    Policy --> Workflow

    %% =====================================================
    %% Agent
    %% =====================================================

    Workflow --> Agent

    subgraph AgentLayer["BeaconLink Agent"]

        RuntimeMgr["Runtime Manager"]

        Selector["Runtime Selector"]

        Adapter["Runtime Adapter Interface"]

    end

    Agent["Deployment Request"] --> RuntimeMgr

    RuntimeMgr --> Selector
    Selector --> Adapter

    %% =====================================================
    %% Runtime Providers
    %% =====================================================

    subgraph Providers["Runtime Providers"]

        Docker["Docker Provider"]
        Containerd["containerd Provider"]
        Kubernetes["Kubernetes Provider"]
        VM["Virtual Machine Provider"]
        Wasm["WebAssembly Provider"]

    end

    Adapter --> Docker
    Adapter --> Containerd
    Adapter --> Kubernetes
    Adapter --> VM
    Adapter --> Wasm

    %% =====================================================
    %% Execution Targets
    %% =====================================================

    subgraph Targets["Execution Environments"]

        Containers["Containers"]
        Pods["Kubernetes Pods"]
        VirtualMachines["Virtual Machines"]
        WasmModules["WebAssembly Modules"]

    end

    Docker --> Containers
    Containerd --> Containers
    Kubernetes --> Pods
    VM --> VirtualMachines
    Wasm --> WasmModules

    %% =====================================================
    %% Feedback Loop
    %% =====================================================

    Containers --> Status["Runtime Status"]
    Pods --> Status
    VirtualMachines --> Status
    WasmModules --> Status

    Status --> RuntimeMgr
    RuntimeMgr --> Deploy

    %% =====================================================
    %% Selection Inputs
    %% =====================================================

    Requirements["Application Requirements"]
    Policies["Deployment Policies"]
    Capabilities["Agent Capabilities"]

    Requirements --> Selector
    Policies --> Selector
    Capabilities --> Selector

    %% =====================================================
    %% Runtime Independence
    %% =====================================================

    Note["Applications target the Runtime Abstraction Layer—not individual runtimes."]

    Note -.-> Adapter

