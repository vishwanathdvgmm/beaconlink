# ============================================================================
# EditorConfig
#
# https://editorconfig.org/
#
# This file helps maintain consistent coding styles across different editors
# and IDEs.
# ============================================================================

root = true

# ----------------------------------------------------------------------------
# Global Defaults
# ----------------------------------------------------------------------------

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ----------------------------------------------------------------------------
# Go
# ----------------------------------------------------------------------------

[*.go]
indent_style = tab
indent_size = 4

# ----------------------------------------------------------------------------
# Go Module Files
# ----------------------------------------------------------------------------

[go.mod]
indent_style = tab

[go.sum]
indent_style = tab

# ----------------------------------------------------------------------------
# Makefile
# ----------------------------------------------------------------------------

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

# ----------------------------------------------------------------------------
# YAML
# ----------------------------------------------------------------------------

[*.{yaml,yml}]
indent_size = 2

# ----------------------------------------------------------------------------
# JSON
# ----------------------------------------------------------------------------

[*.json]
indent_size = 2

# ----------------------------------------------------------------------------
# TOML
# ----------------------------------------------------------------------------

[*.toml]
indent_size = 2

# ----------------------------------------------------------------------------
# Markdown
# ----------------------------------------------------------------------------

[*.md]
indent_size = 2
trim_trailing_whitespace = false

# ----------------------------------------------------------------------------
# Shell Scripts
# ----------------------------------------------------------------------------

[*.sh]
indent_size = 2

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------

[Dockerfile]
indent_size = 2

[Dockerfile.*]
indent_size = 2

# ----------------------------------------------------------------------------
# JavaScript / TypeScript
# ----------------------------------------------------------------------------

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

# ----------------------------------------------------------------------------
# HTML
# ----------------------------------------------------------------------------

[*.html]
indent_size = 2

# ----------------------------------------------------------------------------
# CSS
# ----------------------------------------------------------------------------

[*.{css,scss,sass}]
indent_size = 2

# ----------------------------------------------------------------------------
# XML
# ----------------------------------------------------------------------------

[*.xml]
indent_size = 2

# ----------------------------------------------------------------------------
# SQL
# ----------------------------------------------------------------------------

[*.sql]
indent_size = 2

# ----------------------------------------------------------------------------
# GitHub Actions
# ----------------------------------------------------------------------------

[.github/workflows/*.{yml,yaml}]
indent_size = 2

# ----------------------------------------------------------------------------
# Ignore Binary Files
# ----------------------------------------------------------------------------

[*.{png,jpg,jpeg,gif,ico,pdf,zip,gz,tar,woff,woff2}]
insert_final_newline = false
trim_trailing_whitespace = false