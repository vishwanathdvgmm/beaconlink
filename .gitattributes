# ============================================================================
# BeaconLink .gitattributes
#
# This file standardizes line endings, improves Git diffs, and identifies
# generated or binary files.
#
# Documentation:
# https://git-scm.com/docs/gitattributes
# ============================================================================

# ----------------------------------------------------------------------------
# Default Text Handling
# ----------------------------------------------------------------------------

* text=auto eol=lf

# ----------------------------------------------------------------------------
# Source Code
# ----------------------------------------------------------------------------

*.go          text
*.mod         text
*.sum         text

*.js          text
*.jsx         text
*.ts          text
*.tsx         text

*.css         text
*.scss        text
*.sass        text

*.html        text

*.json        text
*.yaml        text
*.yml         text
*.toml        text

*.sql         text

*.sh          text eol=lf

*.md          text

*.proto       text

*.mmd         text

# ----------------------------------------------------------------------------
# Windows Scripts
# ----------------------------------------------------------------------------

*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------

Dockerfile    text

Dockerfile.*  text

# ----------------------------------------------------------------------------
# GitHub
# ----------------------------------------------------------------------------

.github/**    text

# ----------------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------------

.editorconfig text

.gitattributes text

.gitignore    text

# ----------------------------------------------------------------------------
# Binary Files
# ----------------------------------------------------------------------------

*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary

*.pdf         binary

*.zip         binary
*.tar         binary
*.gz          binary
*.tgz         binary
*.7z          binary

*.exe         binary
*.dll         binary
*.so          binary
*.dylib

*.woff        binary
*.woff2       binary
*.ttf         binary
*.otf         binary

# ----------------------------------------------------------------------------
# Certificates & Keys
# ----------------------------------------------------------------------------

*.pem         text
*.crt         text
*.cer         text
*.csr         text
*.key         text

# ----------------------------------------------------------------------------
# Generated Files
# ----------------------------------------------------------------------------

# Generated code (if committed)
*.pb.go       linguist-generated
*.gen.go      linguist-generated

# sqlc generated files
**/db/*.sql.go linguist-generated

# ----------------------------------------------------------------------------
# Vendored Code
# ----------------------------------------------------------------------------

vendor/** linguist-vendored

# ----------------------------------------------------------------------------
# Documentation
# ----------------------------------------------------------------------------

docs/**/*.md text

docs/**/*.mmd text

# ----------------------------------------------------------------------------
# Merge Strategy
# ----------------------------------------------------------------------------

go.sum merge=union

# ----------------------------------------------------------------------------
# Linguist Overrides
# ----------------------------------------------------------------------------

docs/** linguist-documentation

test/** linguist-detectable=false